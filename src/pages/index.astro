      </a>
      <a href="/blog/cracked-window-well-cover-replacement/" style="display:flex;flex-direction:column;background:#fff;border-radius:16px;overflow:hidden;text-decoration:none;box-shadow:0 4px 16px rgba(10,61,92,0.1);">
        <img src="/images/tile-3.webp" alt="A cracked plastic window well cover needing replacement" width="700" height="560" style="width:100%;aspect-ratio:1.25/1;object-fit:cover;display:block;" loading="lazy">
        <span style="font-family:'Nunito Sans',sans-serif;font-size:14.5px;font-weight:800;color:#0A3D5C;padding:14px 12px;">Cracked or broken window well cover</span>
      </a>
      <a href="/blog/bowing-window-well-wall/" style="display:flex;flex-direction:column;background:#fff;border-radius:16px;overflow:hidden;text-decoration:none;box-shadow:0 4px 16px rgba(10,61,92,0.1);">
        <img src="/images/tile-4.webp" alt="A corrugated metal window well wall bowing away from the foundation" width="700" height="560" style="width:100%;aspect-ratio:1.25/1;object-fit:cover;display:block;" loading="lazy">
        <span style="font-family:'Nunito Sans',sans-serif;font-size:14.5px;font-weight:800;color:#0A3D5C;padding:14px 12px;">Window well wall bowing or pulling away</span>
      </a>
      <a href="/egress-window-installation-lincoln/" style="display:flex;flex-direction:column;background:#fff;border-radius:16px;overflow:hidden;text-decoration:none;box-shadow:0 4px 16px rgba(10,61,92,0.1);">
        <img src="/images/service-1.webp" alt="New egress window cut into a Lincoln basement wall" width="700" height="560" style="width:100%;aspect-ratio:1.25/1;object-fit:cover;display:block;" loading="lazy">
        <span style="font-family:'Nunito Sans',sans-serif;font-size:14.5px;font-weight:800;color:#0A3D5C;padding:14px 12px;">New egress window installation</span>
      </a>
      <a href="/egress-window-replacement-lincoln/" style="display:flex;flex-direction:column;background:#fff;border-radius:16px;overflow:hidden;text-decoration:none;box-shadow:0 4px 16px rgba(10,61,92,0.1);">
        <img src="/images/service-2.webp" alt="Old basement window being replaced with a code-compliant egress window" width="700" height="560" style="width:100%;aspect-ratio:1.25/1;object-fit:cover;display:block;" loading="lazy">
        <span style="font-family:'Nunito Sans',sans-serif;font-size:14.5px;font-weight:800;color:#0A3D5C;padding:14px 12px;">Egress window replacement</span>
      </a>
      <a href="/window-well-installation-lincoln/" style="display:flex;flex-direction:column;background:#fff;border-radius:16px;overflow:hidden;text-decoration:none;box-shadow:0 4px 16px rgba(10,61,92,0.1);">
        <img src="/images/service-3.webp" alt="Window well with gravel base and drainage installed below grade" width="700" height="560" style="width:100%;aspect-ratio:1.25/1;object-fit:cover;display:block;" loading="lazy">
        <span style="font-family:'Nunito Sans',sans-serif;font-size:14.5px;font-weight:800;color:#0A3D5C;padding:14px 12px;">Window well installation and drainage</span>
      </a>
      <a href="/basement-window-replacement-lincoln/" style="display:flex;flex-direction:column;background:#fff;border-radius:16px;overflow:hidden;text-decoration:none;box-shadow:0 4px 16px rgba(10,61,92,0.1);">
        <img src="/images/service-4.webp" alt="Standard basement window being swapped out for a new unit" width="700" height="560" style="width:100%;aspect-ratio:1.25/1;object-fit:cover;display:block;" loading="lazy">
        <span style="font-family:'Nunito Sans',sans-serif;font-size:14.5px;font-weight:800;color:#0A3D5C;padding:14px 12px;">Basement window replacement</span>
