    <h2 class="section-heading" style="font-size:clamp(26px,3.4vw,40px);margin:0 0 40px;">What's Going On With Your Basement Window?</h2>
    <div class="tile-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:22px;">
      <a href="/blog/leaking-window-well/" style="display:flex;flex-direction:column;background:#fff;border-radius:16px;overflow:hidden;text-decoration:none;box-shadow:0 4px 16px rgba(10,61,92,0.1);">
        <img src="/images/tile-1.webp" alt="Water pooling in a leaking window well against a Lincoln foundation" width="700" height="560" style="width:100%;aspect-ratio:1.25/1;object-fit:cover;display:block;" loading="lazy">
        <span style="font-family:'Nunito Sans',sans-serif;font-size:14.5px;font-weight:800;color:#0A3D5C;padding:14px 12px;">Window well leaking after every rain</span>
      </a>
      <a href="/blog/stuck-egress-window/" style="display:flex;flex-direction:column;background:#fff;border-radius:16px;overflow:hidden;text-decoration:none;box-shadow:0 4px 16px rgba(10,61,92,0.1);">
        <img src="/images/tile-2.webp" alt="A stuck basement egress window that will not open in an emergency" width="700" height="560" style="width:100%;aspect-ratio:1.25/1;object-fit:cover;display:block;" loading="lazy">
