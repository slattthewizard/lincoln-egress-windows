---
export interface Props {
  title: string;
  description: string;
  canonical: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
}

const {
  title,
  description,
  canonical,
  ogTitle,
  ogDescription,
  ogImage = 'https://lincolnegresswindows.com/images/og-image.webp',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml">
  <title>{title}</title>
  <meta name="google-site-verification" content="N33Yu1FGaMjIpBbcnZVWlm4kUjmvfwinVnZUOq5p21k" />
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={ogTitle ?? title} />
  <meta property="og:description" content={ogDescription ?? description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Lincoln Egress Windows" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle ?? title} />
  <meta name="twitter:description" content={ogDescription ?? description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito+Sans:wght@400;600;700;800&family=Inter:wght@400;500;600&display=swap"></noscript>

  <!-- Shared base styles -->
  <style is:global>
    :root {
      --deep: #0A3D5C;       /* footer / dark blue */
      --primary: #1273A8;    /* brand blue */
      --primary-dark: #0C5680;
      --green: #2FA34D;      /* CTA green */
      --green-dark: #268A40;
      --sky: #EAF5FB;        /* tinted section background */
      --ink: #2B3A44;        /* body text */
      --muted: #5A6B76;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Inter', 'Segoe UI', Arial, sans-serif; color: #2B3A44; background: #fff; margin: 0; }
    h1, h2, h3, h4 { font-family: 'Nunito Sans', 'Segoe UI', Arial, sans-serif; }

    /* Nav */
    .nav-link {
      font-weight: 600; font-size: 14px; color: #2B3A44; text-decoration: none;
      padding: 8px 2px; transition: color 0.2s; border-bottom: 2px solid transparent;
    }
    .nav-link:hover { color: #1273A8; border-bottom-color: #1273A8; }
    .nav-link:focus-visible { outline: 2px solid #1273A8; outline-offset: 4px; border-radius: 2px; }

    /* Dropdowns */
    .dropdown-open .svc-dropdown { opacity:1 !important; visibility:visible !important; transform:translateY(0) !important; }
    .dropdown-open svg { transform: rotate(180deg); }
    .areas-open .areas-dropdown { opacity:1 !important; visibility:visible !important; transform:translateY(0) !important; }
    .areas-open svg { transform: rotate(180deg); }
    .dropdown-link { display: flex; align-items: center; padding: 11px 18px; min-height: 44px; font-size: 14px; font-weight: 500; color: #2B3A44; text-decoration: none; transition: background-color 0.2s, color 0.2s; outline: none; }
    .dropdown-link:hover { background-color: #EAF5FB; color: #1273A8; }
    .dropdown-link:focus-visible { background-color: #EAF5FB; color: #1273A8; box-shadow: inset 2px 0 0 0 #1273A8; }
    .dropdown-link:active { opacity: 0.7; }

    /* Pill buttons */
    .btn-green {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      background: #2FA34D; color: #fff; font-family: 'Nunito Sans', sans-serif;
      font-weight: 800; font-size: 14px; letter-spacing: 0.02em;
      padding: 14px 32px; border: none; border-radius: 999px; cursor: pointer; text-decoration: none;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 6px 18px rgba(47,163,77,0.35);
    }
    .btn-green:hover { background: #268A40; transform: translateY(-1px); box-shadow: 0 8px 24px rgba(47,163,77,0.45); }
    .btn-green:active { transform: translateY(0); }
    .btn-green:focus-visible { outline: 3px solid #BDE6C8; outline-offset: 2px; }

    .btn-blue {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      background: #1273A8; color: #fff; font-family: 'Nunito Sans', sans-serif;
      font-weight: 800; font-size: 14px; letter-spacing: 0.02em;
      padding: 14px 32px; border: none; border-radius: 999px; cursor: pointer; text-decoration: none;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
      box-shadow: 0 6px 18px rgba(18,115,168,0.3);
    }
    .btn-blue:hover { background: #0C5680; transform: translateY(-1px); }
    .btn-blue:active { transform: translateY(0); }
    .btn-blue:focus-visible { outline: 3px solid #BFE0F2; outline-offset: 2px; }

    .btn-white-outline {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      background: rgba(255,255,255,0.12); color: #fff; font-family: 'Nunito Sans', sans-serif;
      font-weight: 700; font-size: 14px; padding: 13px 30px;
      border: 2px solid rgba(255,255,255,0.8); border-radius: 999px; cursor: pointer; text-decoration: none;
      transition: background 0.2s, transform 0.15s; backdrop-filter: blur(2px);
    }
    .btn-white-outline:hover { background: rgba(255,255,255,0.22); transform: translateY(-1px); }
    .btn-white-outline:active { transform: translateY(0); }
    .btn-white-outline:focus-visible { outline: 3px solid #BFE0F2; outline-offset: 2px; }
    /* alias: inner pages use the reversed class name */
    .btn-outline-white {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      background: rgba(255,255,255,0.12); color: #fff; font-family: 'Nunito Sans', sans-serif;
      font-weight: 700; font-size: 14px; padding: 13px 30px;
      border: 2px solid rgba(255,255,255,0.8); border-radius: 999px; cursor: pointer; text-decoration: none;
      transition: background 0.2s, transform 0.15s; backdrop-filter: blur(2px);
    }
    .btn-outline-white:hover { background: rgba(255,255,255,0.22); transform: translateY(-1px); }
    .btn-outline-white:focus-visible { outline: 3px solid #BFE0F2; outline-offset: 2px; }

    /* Curved divider under heroes */
    .swoosh { display: block; width: 100%; height: 70px; margin-top: -1px; }

    /* Legacy class mapping (inner pages) onto the pill design system */
    .btn-primary {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      background: #1273A8; color: #fff; font-family: 'Nunito Sans', sans-serif;
      font-weight: 800; font-size: 14px; padding: 14px 32px; border: none;
      border-radius: 999px; cursor: pointer; text-decoration: none;
      transition: background 0.2s, transform 0.15s; box-shadow: 0 6px 18px rgba(18,115,168,0.3);
    }
    .btn-primary:hover { background: #0C5680; transform: translateY(-1px); }
    .btn-copper, .btn-bark {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      background: #2FA34D; color: #fff; font-family: 'Nunito Sans', sans-serif;
      font-weight: 800; font-size: 14px; padding: 14px 32px; border: none;
      border-radius: 999px; cursor: pointer; text-decoration: none;
      transition: background 0.2s, transform 0.15s; box-shadow: 0 6px 18px rgba(47,163,77,0.35);
    }
    .btn-copper:hover, .btn-bark:hover { background: #268A40; transform: translateY(-1px); }
    .btn-cream {
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
      background: #fff; color: #0A3D5C; font-family: 'Nunito Sans', sans-serif;
      font-weight: 800; font-size: 14px; padding: 14px 32px; border: none;
      border-radius: 999px; cursor: pointer; text-decoration: none;
      transition: transform 0.15s, box-shadow 0.2s; box-shadow: 0 6px 18px rgba(0,0,0,0.18);
    }
    .btn-cream:hover { transform: translateY(-1px); box-shadow: 0 10px 26px rgba(0,0,0,0.24); }
    .section-tag {
      display: inline-block; font-family: 'Nunito Sans', sans-serif; font-size: 12px; font-weight: 800;
      letter-spacing: 0.16em; text-transform: uppercase; color: #2FA34D; margin-bottom: 10px;
    }

    /* Section helpers */
    .kicker {
      display: inline-block; font-family: 'Nunito Sans', sans-serif; font-size: 12px; font-weight: 800;
      letter-spacing: 0.16em; text-transform: uppercase; color: #2FA34D; margin-bottom: 10px;
    }
    .section-heading {
      font-family: 'Nunito Sans', sans-serif; font-weight: 800; color: #0A3D5C;
      line-height: 1.12; letter-spacing: -0.01em;
    }

    /* Footer */
    .footer-link {
      font-size: 14px; color: rgba(255,255,255,0.72); text-decoration: none;
      transition: color 0.2s; outline: none; display: inline-block;
    }
    .footer-link:hover { color: #fff; }
    .footer-link:focus-visible { outline: 2px solid #7FC4E8; outline-offset: 2px; border-radius: 2px; color: #fff; }

    /* Mobile nav */
    #mobile-menu { display: none; }
    #mobile-menu.open { display: block; }
    .desktop-nav { display: none; }
    .menu-btn { display: inline-flex; }
    @media (min-width: 960px) {
      .desktop-nav { display: flex; }
      .menu-btn { display: none; }
      .desktop-cta { display: inline-flex !important; }
    }

    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #EAF5FB; }
    ::-webkit-scrollbar-thumb { background: #1273A8; border-radius: 3px; }
  </style>

  <!-- Page-specific head content (schema, extra styles) -->
  <slot name="head" />

  <script>document.addEventListener('click',function(e){document.querySelectorAll('.dropdown-open').forEach(function(d){if(!d.contains(e.target))d.classList.remove('dropdown-open')});document.querySelectorAll('.areas-open').forEach(function(d){if(!d.contains(e.target))d.classList.remove('areas-open')})});</script>
</head>
<body>

<!-- ANNOUNCEMENT STRIP -->
<div style="background:#2FA34D;padding:7px 24px;">
  <div style="max-width:1220px;margin:0 auto;display:flex;align-items:center;justify-content:center;gap:28px;flex-wrap:wrap;">
    <span style="color:#fff;font-size:12.5px;font-weight:700;display:flex;align-items:center;gap:6px;">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      Most Egress Installs Done in One Day
    </span>
    <span style="color:rgba(255,255,255,0.92);font-size:12.5px;font-weight:600;" class="strip-extra">Serving Lincoln &amp; Southeast Nebraska</span>
    <a href="tel:+15092243484" style="color:#fff;font-size:12.5px;font-weight:800;text-decoration:none;display:flex;align-items:center;gap:6px;">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.5 12 19.79 19.79 0 0 1 1.1 3.18a2 2 0 0 1 2-2.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.27a16 16 0 0 0 7.82 7.82l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      (509) 224-3484
    </a>
  </div>
</div>
<style>
  @media (max-width: 640px) { .strip-extra { display: none; } }
</style>

<!-- STICKY NAV -->
<header style="position:sticky;top:0;z-index:100;background:#fff;box-shadow:0 2px 14px rgba(10,61,92,0.1);">
  <div style="max-width:1220px;margin:0 auto;padding:0 24px;display:flex;align-items:center;justify-content:space-between;height:76px;">
    <!-- Logo -->
    <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none;" aria-label="Lincoln Egress Windows home">
      <svg width="40" height="40" viewBox="0 0 36 36" fill="none" aria-hidden="true">
        <circle cx="18" cy="18" r="17" fill="#1273A8"/>
        <text x="18" y="24" text-anchor="middle" font-family="Nunito Sans, sans-serif" font-size="17" font-weight="800" fill="#fff">L</text>
      </svg>
      <span style="display:flex;flex-direction:column;line-height:1.05;">
        <span style="font-family:'Nunito Sans',sans-serif;font-weight:800;font-size:20px;color:#0A3D5C;letter-spacing:-0.01em;">Lincoln Egress Windows</span>
        <span style="font-size:10px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#2FA34D;">Egress Windows &amp; Window Wells</span>
      </span>
    </a>

    <!-- Desktop Nav -->
    <nav class="desktop-nav" style="align-items:center;gap:26px;">
      <div style="position:relative;">
        <button onclick="this.parentElement.classList.toggle('dropdown-open')" class="nav-link" style="background:none;border:none;cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:5px;min-height:44px;">
          Services
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="transition:transform 0.2s;"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="svc-dropdown" style="position:absolute;top:calc(100% + 6px);left:0;min-width:260px;background:#fff;border-radius:14px;box-shadow:0 8px 30px rgba(10,61,92,0.16);padding:8px 0;opacity:0;visibility:hidden;transform:translateY(-8px);transition:opacity 0.2s,transform 0.2s,visibility 0.2s;z-index:100;overflow:hidden;">
          <a href="/egress-window-installation-lincoln/" class="dropdown-link">Egress Window Installation</a>
          <a href="/egress-window-replacement-lincoln/" class="dropdown-link">Egress Window Replacement</a>
          <a href="/window-well-installation-lincoln/" class="dropdown-link">Window Well Installation & Drainage</a>
          <a href="/basement-window-replacement-lincoln/" class="dropdown-link">Basement Window Replacement</a>
        </div>
      </div>
      <div style="position:relative;">
        <button onclick="this.parentElement.classList.toggle('areas-open')" class="nav-link" style="background:none;border:none;cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;gap:5px;min-height:44px;">
          Service Areas
          <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="transition:transform 0.2s;"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="areas-dropdown" style="position:absolute;top:calc(100% + 6px);left:0;min-width:230px;background:#fff;border-radius:14px;box-shadow:0 8px 30px rgba(10,61,92,0.16);padding:8px 0;opacity:0;visibility:hidden;transform:translateY(-8px);transition:opacity 0.2s,transform 0.2s,visibility 0.2s;z-index:100;overflow:hidden;">
          <a href="/egress-windows-waverly/" class="dropdown-link">Waverly</a>
          <a href="/egress-windows-hickman/" class="dropdown-link">Hickman</a>
          <a href="/egress-windows-seward/" class="dropdown-link">Seward</a>
          <a href="/egress-windows-crete/" class="dropdown-link">Crete</a>
          <a href="/egress-windows-beatrice/" class="dropdown-link">Beatrice</a>
          <a href="/egress-windows-ashland/" class="dropdown-link">Ashland</a>
        </div>
      </div>
      <a href="/egress-window-cost/" class="nav-link">Cost Guide</a>
      <a href="/about/" class="nav-link">About</a>
      <a href="/blog/" class="nav-link">Blog</a>
    </nav>

    <!-- CTA -->
    <div class="desktop-cta" style="display:none;align-items:center;gap:12px;">
      <a href="/#contact" class="btn-green" style="padding:12px 26px;font-size:13.5px;">Request Service</a>
    </div>

    <!-- Mobile hamburger -->
    <button class="menu-btn" onclick="document.getElementById('mobile-menu').classList.toggle('open')" aria-label="Toggle menu" style="background:none;border:none;cursor:pointer;padding:12px;min-width:44px;min-height:44px;color:#0A3D5C;">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>

  <!-- Mobile Nav -->
  <div id="mobile-menu" style="border-top:1px solid #E2EBF1;background:#fff;">
    <nav style="display:flex;flex-direction:column;padding:16px 24px;gap:14px;">
      <a href="/egress-window-installation-lincoln/" class="nav-link" onclick="document.getElementById('mobile-menu').classList.remove('open')">Egress Window Installation</a>
      <a href="/egress-window-replacement-lincoln/" class="nav-link" onclick="document.getElementById('mobile-menu').classList.remove('open')">Egress Window Replacement</a>
      <a href="/window-well-installation-lincoln/" class="nav-link" onclick="document.getElementById('mobile-menu').classList.remove('open')">Window Well Installation & Drainage</a>
      <a href="/basement-window-replacement-lincoln/" class="nav-link" onclick="document.getElementById('mobile-menu').classList.remove('open')">Emergency Service</a>
      <a href="/egress-window-cost/" class="nav-link" onclick="document.getElementById('mobile-menu').classList.remove('open')">Cost Guide</a>
      <a href="/about/" class="nav-link" onclick="document.getElementById('mobile-menu').classList.remove('open')">About</a>
      <a href="/blog/" class="nav-link" onclick="document.getElementById('mobile-menu').classList.remove('open')">Blog</a>
      <a href="/#contact" class="btn-green" style="width:fit-content;font-size:13px;padding:11px 24px;" onclick="document.getElementById('mobile-menu').classList.remove('open')">Request Service</a>
    </nav>
  </div>
</header>

<!-- PAGE CONTENT -->
<slot />

<!-- FOOTER -->
<footer style="background:#0A3D5C;color:rgba(255,255,255,0.78);padding:0;">
  <!-- Footer CTA band -->
  <div style="background:#1273A8;padding:36px 24px;">
    <div style="max-width:1220px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;">
      <div>
        <p style="font-family:'Nunito Sans',sans-serif;font-size:22px;font-weight:800;color:#fff;margin:0 0 4px;">Basement project on the clock? We pick up.</p>
        <p style="font-size:14px;color:rgba(255,255,255,0.85);margin:0;">Free written estimates across Lincoln &amp; Southeast Nebraska.</p>
      </div>
      <div style="display:flex;gap:14px;flex-wrap:wrap;">
        <a href="tel:+15092243484" class="btn-white-outline">Call (509) 224-3484</a>
        <a href="/#contact" class="btn-green">Request Service</a>
      </div>
    </div>
  </div>

  <div style="max-width:1220px;margin:0 auto;padding:56px 24px 0;">
    <div class="footer-grid" style="display:grid;grid-template-columns:2fr 1fr 1fr 1.5fr;gap:48px;padding-bottom:44px;border-bottom:1px solid rgba(255,255,255,0.12);">
      <!-- Brand -->
      <div>
        <p style="font-family:'Nunito Sans',sans-serif;font-size:20px;font-weight:800;color:#fff;margin:0 0 12px;">Lincoln Egress Windows</p>
        <p style="font-size:14px;line-height:1.8;max-width:300px;margin-bottom:20px;">Egress window installation, replacement, and window well service for Lincoln &amp; Southeast Nebraska. Licensed, insured, and on call for inspection and closing deadlines.</p>
      </div>
      <!-- Services -->
      <div>
        <p style="font-family:'Nunito Sans',sans-serif;font-size:15px;font-weight:800;color:#fff;margin-bottom:16px;letter-spacing:0.04em;text-transform:uppercase;">Services</p>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
          <li><a href="/egress-window-installation-lincoln/" class="footer-link">Egress Window Installation</a></li>
          <li><a href="/egress-window-replacement-lincoln/" class="footer-link">Egress Window Replacement</a></li>
          <li><a href="/window-well-installation-lincoln/" class="footer-link">Window Well Installation & Drainage</a></li>
          <li><a href="/basement-window-replacement-lincoln/" class="footer-link">Basement Window Replacement</a></li>
          <li><a href="/egress-window-cost/" class="footer-link">Egress Window Cost Guide</a></li>
        </ul>
      </div>
      <!-- Service Areas -->
      <div>
        <p style="font-family:'Nunito Sans',sans-serif;font-size:15px;font-weight:800;color:#fff;margin-bottom:16px;letter-spacing:0.04em;text-transform:uppercase;">Service Areas</p>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:10px;">
          <li><a href="/egress-windows-waverly/" class="footer-link">Waverly</a></li>
          <li><a href="/egress-windows-hickman/" class="footer-link">Hickman</a></li>
          <li><a href="/egress-windows-seward/" class="footer-link">Seward</a></li>
          <li><a href="/egress-windows-crete/" class="footer-link">Crete</a></li>
          <li><a href="/egress-windows-beatrice/" class="footer-link">Beatrice</a></li>
          <li><a href="/egress-windows-ashland/" class="footer-link">Ashland</a></li>
        </ul>
      </div>
      <!-- Contact -->
      <div>
        <p style="font-family:'Nunito Sans',sans-serif;font-size:15px;font-weight:800;color:#fff;margin-bottom:16px;letter-spacing:0.04em;text-transform:uppercase;">Contact</p>
