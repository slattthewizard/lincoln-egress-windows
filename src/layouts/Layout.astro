<script>
(function () {
  'use strict';
  function scrollPct() {
    var el = document.documentElement;
    var s = (window.scrollY || el.scrollTop), m = el.scrollHeight - el.clientHeight;
    return m > 0 ? s / m : 0;
  }
  function nearContact() {
    var sec = document.querySelector('#contact');
    if (!sec) return false;
    var r = sec.getBoundingClientRect();
    return r.top < window.innerHeight + 120 && r.bottom > -120;
  }
  // Mobile bar
  var bar = document.getElementById('wwpMobileBar');
  var barX = document.getElementById('wwpMobileBarDismiss');
  if (bar && barX && !sessionStorage.getItem('wwp_bar_dismissed')) {
    var shown = false, dismissed = false, t1 = false;
    function update() {
      if (dismissed) return;
      if (!shown && scrollPct() >= 0.25) { shown = true; bar.classList.add('wwp-bar-visible'); bar.setAttribute('aria-hidden', 'false'); }
      if (shown) bar.classList.toggle('wwp-bar-near-contact', nearContact());
    }
    window.addEventListener('scroll', function () {
      if (!t1) { requestAnimationFrame(function () { update(); t1 = false; }); t1 = true; }
    }, { passive: true });
    barX.addEventListener('click', function () {
      dismissed = true; sessionStorage.setItem('wwp_bar_dismissed', '1');
      bar.classList.remove('wwp-bar-visible'); bar.setAttribute('aria-hidden', 'true');
    });
  }
  // Desktop blog slide-in
  var slide = document.getElementById('wwpDesktopSlide');
  var slideX = document.getElementById('wwpDesktopSlideDismiss');
  var onBlog = location.pathname.indexOf('/blog/') === 0 && location.pathname !== '/blog/';
  if (slide && slideX && onBlog && !sessionStorage.getItem('wwp_slide_dismissed')) {
    var sShown = false, t2 = false;
    window.addEventListener('scroll', function () {
      if (!t2) { requestAnimationFrame(function () {
        if (!sShown && scrollPct() >= 0.6) { sShown = true; slide.classList.add('wwp-bar-visible'); slide.setAttribute('aria-hidden', 'false'); }
        t2 = false;
      }); t2 = true; }
    }, { passive: true });
    slideX.addEventListener('click', function () {
      sessionStorage.setItem('wwp_slide_dismissed', '1');
      slide.classList.remove('wwp-bar-visible'); slide.setAttribute('aria-hidden', 'true');
    });
  }
})();
</script>

<!-- GA4 (set GA_ID to enable) + lightweight event tracking -->
<script>
(function () {
  var GA_ID = 'G-G41D09PK6V';
  if (GA_ID) {
    function loadGA() {
      var s = document.createElement('script');
      s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_ID;
      s.async = true;
      document.head.appendChild(s);
      window.dataLayer = window.dataLayer || [];
      window.gtag = function(){ dataLayer.push(arguments); };
      gtag('js', new Date());
      gtag('config', GA_ID, { anonymize_ip: true });
    }
    if ('requestIdleCallback' in window) requestIdleCallback(loadGA, { timeout: 4000 });
    else setTimeout(loadGA, 3500);
  }
  function track(name, params) {
    if (typeof window.gtag === 'function') window.gtag('event', name, params);
  }
  document.addEventListener('click', function (e) {
    var tel = e.target.closest('a[href^="tel:"]');
    if (tel) {
      track('phone_click', { link_text: tel.textContent.trim().slice(0, 100), page_path: location.pathname });
      return;
    }
    var btn = e.target.closest('a.btn-green, a.btn-blue, a.btn-primary, a.btn-copper, a.btn-bark, a.btn-cream, a.btn-white-outline, a.btn-outline-white, a.wwp-tracked');
    if (btn) track('cta_click', { button_text: btn.textContent.trim().slice(0, 100), link_url: btn.getAttribute('href') || '', page_path: location.pathname });
  });
  var started = false;
  document.addEventListener('focusin', function (e) {
    if (started) return;
    if (e.target.closest('#contact-form')) { started = true; track('form_start', { form_name: 'estimate_request', page_path: location.pathname }); }
  });
  document.addEventListener('submit', function (e) {
    if (e.target.closest('#contact-form')) track('form_submit_attempt', { form_name: 'estimate_request', page_path: location.pathname });
  });
})();
</script>

