{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.lincolnegresswindows.com" }],
      "destination": "https://lincolnegresswindows.com/$1",
      "statusCode": 308
    },
    { "source": "/sitemap.xml", "destination": "/sitemap-index.xml", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/_astro/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
